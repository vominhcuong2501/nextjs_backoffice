#!/bin/bash
# Purpose: Deploy backup server first, then live server, with PM2 start/restart management.

echo "Starting deployment..."

live_server="ntbipcom"
backup_server="ntbipcom_bk"

pm2_ecosystem="ecosystem.config.js"

pm2_name="${NEXT_PUBLIC_APP_NAME}_${NEXT_PUBLIC_APP_PORT}"
pm2_name_bk="${NEXT_PUBLIC_APP_NAME}_${NEXT_PUBLIC_APP_PORT}_bk"

live_server_dir="../$live_server"
backup_server_dir="../$backup_server"

function start_or_restart() {
  local name=$1
  local namespace=$2

  if pm2 describe "$namespace" > /dev/null; then
    echo "Process $namespace exists. Restarting..."
    pm2 restart "$name"
  else
    echo "Process $name does not exist. Starting new process..."
    mkdir -p logs
    pm2 start "$name"
  fi
}

if [ ! -d "$backup_server_dir" ]; then
  echo "Backup folder not found. Copying from live server..."
  if [ ! -d "$live_server_dir" ]; then
    echo "Live server folder does not exist. Cannot create backup. Aborting."
    exit 1
  fi
  cp -r "$live_server_dir" "$backup_server_dir"
  echo "Backup folder created."
fi

echo "Deploying backup server..."
cd "$backup_server_dir" || { echo "Failed to cd into backup server folder"; exit 1; }

echo "Pulling latest code..."
if ! git pull; then
  echo "Git pull failed for backup server! Aborting deploy."
  exit 1
fi

rm -rf .next

echo "Installing dependencies..."
if ! pnpm install; then
  echo "pnpm install failed for backup server! Aborting deploy."
  exit 1
fi

echo "Building project..."
if ! pnpm build; then
  echo "Build failed for backup server! Aborting deploy."
  exit 1
fi

start_or_restart "$pm2_ecosystem" "$pm2_name_bk"

echo "Deploying live server..."
cd "$live_server_dir" || { echo "Failed to cd into live server folder"; exit 1; }

echo "Pulling latest code..."
if ! git pull; then
  echo "Git pull failed for live server! Aborting deploy."
  exit 1
fi

rm -rf .next

echo "Installing dependencies..."
if ! pnpm install ; then
  echo "pnpm install failed for live server! Aborting deploy."
  exit 1
fi

echo "Building project..."
if ! pnpm build; then
  echo "Build failed for live server! Aborting deploy."
  exit 1
fi

start_or_restart "$pm2_ecosystem" "$pm2_name"

echo "Waiting 15 seconds before stopping backup server..."
cd "$backup_server_dir" || exit 1
sleep 15
pm2 stop "$pm2_name_bk"

echo "Deployment completed successfully!"
pm2 save
exit 0
